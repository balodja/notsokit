prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
includedir=${prefix}/@NOTSOKIT_INSTALL_INCLUDE_DIR@
libdir=${exec_prefix}/@NOTSOKIT_INSTALL_LIB_DIR@

Name: notsokit
Description: notsokit
URL: http://localhost/
Version: @NOTSOKIT_VERSION@
Cflags: -I${includedir} @NOTSOKIT_CXX_FLAGS@
Libs: -L${libdir} -l@NOTSOKIT_LIBNAME@
